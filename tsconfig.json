{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "#/*": ["./src/*"]
    },
    "target": "ES2022",
    "baseUrl": "."
  },
  "include": [
    ".astro/types.d.ts",
    "**/*.astro",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ],
  "types": ["@atcute/whitewind", "@atcute/bluesky", "@atcute/atproto"]
}
