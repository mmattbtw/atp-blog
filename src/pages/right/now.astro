---
import { ArrowLeftIcon } from "lucide-react";

import me from "#/assets/matt.jpeg";
import NowList from "#/components/NowList.astro";
import { Paragraph, Title } from "#/components/typography";
import Link from "#/components/ui/link";
import BaseLayout from "#/layouts/base-layout.astro";

---

<BaseLayout
  title="Right Now - mmatt.net"
  description="its- its like its like. <_< ^_^ >_>"
  canonical="/right/now"
>
  <div class="grid grid-rows-[20px_1fr_20px] items-center justify-items-center min-h-dvh p-8 pb-20 gap-16 sm:p-20">
    <main class="flex flex-col gap-8 row-start-2 items-center sm:items-start w-full max-w-[600px]">
      <a
        href="/"
        class="hover:underline hover:underline-offset-4 font-medium"
      >
        <ArrowLeftIcon className="inline size-4 align-middle mb-px mr-1" />
        Back
      </a>
      <div class="self-center flex flex-col">
        <img
          src={me.src}
          alt="Photo of Matt Morris, red hair, glasses, holding his iPhone in the mirror, taking a picture of himself."
          width="100"
          height="100"
          class="rounded-lg"
        />
      </div>

      <Title level="h2">matt: right now</Title>
      <Paragraph>
        view on{" "}
        <Link href="https://bsky.app/profile/did:plc:rwb72l7iwkraojrbrbwitnkd">
          Bluesky
        </Link>{" "}
        and <Link href="https://status.lol/matt">status.lol</Link>.
      </Paragraph>
      <div class="flex flex-col gap-4 w-full">
        <NowList />
      </div>
    </main>
  </div>
</BaseLayout>
